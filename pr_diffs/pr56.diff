+	exec := NewExecutor(ms)
+	chunks, err := exec.Execute(project)
+	if err != nil {
+		t.Fatalf("executeProject type coercion: %v", err)
+	}
+
+	if len(chunks) == 0 || chunks[0].RowCount() == 0 {
+		t.Fatal("expected at least 1 row")
+	}
+
+	col, _ := chunks[0].GetColumn(0)
+	val := col.GetValue(0)
+	if val.Float64 != 30.0 {
