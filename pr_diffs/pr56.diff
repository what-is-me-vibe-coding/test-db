+	// Project Int64 column into Float64 output schema (triggers coerceValue)
+	project := &ProjectNode{
+		Child: scan,
+		Expressions: []Expression{
+			&ResolvedColumnExpr{Name: testColAge, Idx: 2, typ: common.TypeInt64},
+		},
