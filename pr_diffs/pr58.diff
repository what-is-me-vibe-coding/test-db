+	colTypeMap map[string]common.DataType
+}
+
+// ColTypeMap 返回列名到数据类型的映射，延迟初始化并缓存。
+func (t *Table) ColTypeMap() map[string]common.DataType {
+	if t.colTypeMap == nil {
+		m := make(map[string]common.DataType, len(t.Columns))
+		for _, col := range t.Columns {
+			m[col.Name] = col.Type
+		}
+		t.colTypeMap = m
+	}
+	return t.colTypeMap
 }
 
